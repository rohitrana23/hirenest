{
  "info": {
    "name": "HireNest API",
    "description": "Complete API collection for the HireNest job portal",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "PASTE_YOUR_JWT_TOKEN_HERE" },
    { "key": "jobId", "value": "PASTE_A_JOB_ID_HERE" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Recruiter)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Recruiter\",\n  \"email\": \"alice@company.com\",\n  \"password\": \"password123\",\n  \"role\": \"recruiter\"\n}"
            }
          }
        },
        {
          "name": "Register (Job Seeker)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Seeker\",\n  \"email\": \"bob@gmail.com\",\n  \"password\": \"password123\",\n  \"role\": \"seeker\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@company.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Get All Jobs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs"
          }
        },
        {
          "name": "Search Jobs by Title",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/jobs?title=developer",
              "query": [{ "key": "title", "value": "developer" }]
            }
          }
        },
        {
          "name": "Search Jobs by Location",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/jobs?location=bangalore",
              "query": [{ "key": "location", "value": "bangalore" }]
            }
          }
        },
        {
          "name": "Search Jobs by Keyword",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/jobs?keyword=react",
              "query": [{ "key": "keyword", "value": "react" }]
            }
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        },
        {
          "name": "Post a Job (Recruiter)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/jobs",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior React Developer\",\n  \"company\": \"TechCorp India\",\n  \"location\": \"Bangalore, India\",\n  \"salary\": \"₹15–20 LPA\",\n  \"description\": \"We are looking for a talented React developer with 3+ years of experience.\\n\\nResponsibilities:\\n- Build scalable React applications\\n- Collaborate with cross-functional teams\\n- Code reviews and mentoring\\n\\nRequirements:\\n- 3+ years React experience\\n- Strong JavaScript fundamentals\\n- Experience with REST APIs\",\n  \"keywords\": [\"React\", \"JavaScript\", \"Redux\", \"REST API\"]\n}"
            }
          }
        },
        {
          "name": "Update Job (Recruiter)",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/jobs/{{jobId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"salary\": \"₹18–22 LPA\",\n  \"title\": \"Lead React Developer\"\n}"
            }
          }
        },
        {
          "name": "Delete Job (Recruiter)",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/jobs/{{jobId}}",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Get My Job Listings (Recruiter)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/my/listings",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Apply to Job (Seeker)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/jobs/{{jobId}}/apply",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"coverLetter\": \"I am excited about this role because...\"\n}"
            }
          }
        },
        {
          "name": "Get My Applications (Seeker)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/my/applications",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
